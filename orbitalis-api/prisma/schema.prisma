// schema.prisma — Plataforma Orbitalis

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// ENUMs
// ─────────────────────────────────────────

enum UsuarioTipo {
  admin
  tecnico
  cliente
}

enum OsStatus {
  aberta
  agendada
  em_andamento
  concluida
  cancelada
}

enum OsOrigem {
  manual_admin
  preventiva_automatica
  portal_cliente
}

enum AlertaTipo {
  os_atrasada
  os_sem_atualizacao
  equipamento_reincidente
  contrato_vencendo
  plano_vencendo
}

enum AlertaSeveridade {
  info
  aviso
  critico
}

enum OsTipo {
  preventiva
  corretiva
}

enum OsItemStatus {
  pendente
  concluido
}

// ─────────────────────────────────────────
// usuarios
// ─────────────────────────────────────────
model Usuario {
  id            String      @id @default(uuid()) @db.Uuid
  email         String      @unique @db.VarChar(255)
  senhaHash     String      @map("senha_hash") @db.VarChar(255)
  tipo          UsuarioTipo
  nome          String?     @db.VarChar(150)
  telefone      String?     @db.VarChar(20)
  especialidade String?     @db.VarChar(100)
  dataCriacao   DateTime    @default(now()) @map("data_criacao")

  cliente           Cliente?
  ordensComoTecnico OrdemServico[]    @relation("TecnicoOrdens")
  planosComoTecnico PlanoManutencao[] @relation("TecnicoPlanos")

  @@map("usuarios")
}

// ─────────────────────────────────────────
// clientes  (soft delete via deletedAt)
// ─────────────────────────────────────────
model Cliente {
  id           String    @id @default(uuid()) @db.Uuid
  usuarioId    String?   @unique @map("usuario_id") @db.Uuid
  documento    String    @unique @db.VarChar(14)
  razaoSocial  String    @map("razao_social") @db.VarChar(255)
  nomeFantasia String?   @map("nome_fantasia") @db.VarChar(255)
  endereco     String    @db.Text
  telefone     String?   @db.VarChar(20)
  deletedAt    DateTime? @map("deleted_at")

  usuario          Usuario?          @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  ambientes        Ambiente[]
  planosManutencao PlanoManutencao[]
  contratos        Contrato[]

  @@map("clientes")
}

// ─────────────────────────────────────────
// ambientes  (soft delete via deletedAt)
// ─────────────────────────────────────────
model Ambiente {
  id                 String    @id @default(uuid()) @db.Uuid
  clienteId          String    @map("cliente_id") @db.Uuid
  nome               String    @db.VarChar(100)
  metrosQuadrados    Decimal   @map("metros_quadrados") @db.Decimal(10, 2)
  capacidadeTermica  String    @map("capacidade_termica") @db.VarChar(50)
  localizacaoInterna String    @map("localizacao_interna") @db.Text
  deletedAt          DateTime? @map("deleted_at")

  cliente       Cliente        @relation(fields: [clienteId], references: [id])
  equipamentos  Equipamento[]
  ordensServico OrdemServico[]

  @@map("ambientes")
}

// ─────────────────────────────────────────
// equipamentos  (soft delete via deletedAt)
// ─────────────────────────────────────────
model Equipamento {
  id                 String    @id @default(uuid()) @db.Uuid
  ambienteId         String    @map("ambiente_id") @db.Uuid
  codigoQr           String    @unique @map("codigo_qr") @db.VarChar(50)
  nome               String    @db.VarChar(100)
  marca              String    @db.VarChar(100)
  modelo             String?   @db.VarChar(100)
  numeroSerie        String?   @map("numero_serie") @db.VarChar(100)
  tipoEquipamento    String    @map("tipo_equipamento") @db.VarChar(100)
  potencia           String?   @db.VarChar(50)
  dataInstalacao     DateTime? @map("data_instalacao")
  condicao           String?   @db.VarChar(20)
  diagnosticoInicial String?   @map("diagnostico_inicial") @db.Text
  valorAquisicao     Decimal?  @map("valor_aquisicao") @db.Decimal(10, 2)
  deletedAt          DateTime? @map("deleted_at")

  ambiente     Ambiente                @relation(fields: [ambienteId], references: [id])
  itensOs      OrdemServicoItem[]
  planoConfigs PlanoEquipamentoConfig[]

  @@index([codigoQr])
  @@map("equipamentos")
}

// ─────────────────────────────────────────
// modelos_checklist
// ─────────────────────────────────────────
model ModeloChecklist {
  id    String @id @default(uuid()) @db.Uuid
  nome  String @db.VarChar(150)
  itens Json

  planoConfigs PlanoEquipamentoConfig[]

  @@map("modelos_checklist")
}

// ─────────────────────────────────────────
// planos_manutencao  (§US05)
// Um plano por cliente cobre todos os ambientes/equipamentos.
// Gera uma O.S. por ambiente por ciclo.
// ─────────────────────────────────────────
model PlanoManutencao {
  id             String    @id @default(uuid()) @db.Uuid
  clienteId      String    @map("cliente_id") @db.Uuid
  tecnicoId      String?   @map("tecnico_id") @db.Uuid
  frequenciaDias Int       @map("frequencia_dias")
  ativo          Boolean   @default(true)
  proximaGeracao DateTime  @map("proxima_geracao")
  ultimaGeracao  DateTime? @map("ultima_geracao")
  dataFim        DateTime? @map("data_fim")

  cliente            Cliente                  @relation(fields: [clienteId], references: [id])
  tecnico            Usuario?                 @relation("TecnicoPlanos", fields: [tecnicoId], references: [id])
  equipamentosConfig PlanoEquipamentoConfig[]
  ordensServico      OrdemServico[]

  @@index([proximaGeracao, ativo])
  @@map("planos_manutencao")
}

// ─────────────────────────────────────────
// plano_equipamento_config
// Mapeamento equipamento → checklist específico dentro do plano.
// ─────────────────────────────────────────
model PlanoEquipamentoConfig {
  id                String  @id @default(uuid()) @db.Uuid
  planoId           String  @map("plano_id") @db.Uuid
  equipamentoId     String  @map("equipamento_id") @db.Uuid
  modeloChecklistId String? @map("modelo_checklist_id") @db.Uuid

  plano           PlanoManutencao  @relation(fields: [planoId], references: [id], onDelete: Cascade)
  equipamento     Equipamento      @relation(fields: [equipamentoId], references: [id])
  modeloChecklist ModeloChecklist? @relation(fields: [modeloChecklistId], references: [id], onDelete: SetNull)

  @@unique([planoId, equipamentoId])
  @@map("plano_equipamento_config")
}

// ─────────────────────────────────────────
// ordens_servico
// ─────────────────────────────────────────
model OrdemServico {
  id                String    @id @default(uuid()) @db.Uuid
  numero            Int       @default(autoincrement()) @unique
  ambienteId        String    @map("ambiente_id") @db.Uuid
  planoId           String?   @map("plano_id") @db.Uuid
  tecnicoId         String?   @map("tecnico_id") @db.Uuid
  status            OsStatus
  tipo              OsTipo   @default(corretiva)
  origem            OsOrigem
  assinaturaBase64  String?   @map("assinatura_base64") @db.Text
  tipoGas           String?   @map("tipo_gas") @db.VarChar(20)
  quantidadeGasGramas Decimal? @map("quantidade_gas_gramas") @db.Decimal(8, 1)
  observacoesGerais String?   @map("observacoes_gerais") @db.Text
  dataAgendamento   DateTime  @map("data_agendamento")
  dataInicio        DateTime? @map("data_inicio")
  dataConclusao     DateTime? @map("data_conclusao")
  valorMaoObra          Decimal? @map("valor_mao_obra") @db.Decimal(10, 2)
  valorPecas            Decimal? @map("valor_pecas") @db.Decimal(10, 2)
  googleCalendarEventId String?  @map("google_calendar_event_id") @db.VarChar(255)
  dataCriacao           DateTime @default(now()) @map("data_criacao")

  ambiente  Ambiente                        @relation(fields: [ambienteId], references: [id])
  plano     PlanoManutencao?                @relation(fields: [planoId], references: [id], onDelete: SetNull)
  tecnico   Usuario?                        @relation("TecnicoOrdens", fields: [tecnicoId], references: [id])
  itens     OrdemServicoItem[]
  conflitos AuditoriaConflitoSincronizacao[]

  @@index([status])
  @@map("ordens_servico")
}

// ─────────────────────────────────────────
// ordem_servico_itens
// ─────────────────────────────────────────
model OrdemServicoItem {
  id                  String       @id @default(uuid()) @db.Uuid
  ordemServicoId      String       @map("ordem_servico_id") @db.Uuid
  equipamentoId       String       @map("equipamento_id") @db.Uuid
  statusItem          OsItemStatus @default(pendente) @map("status_item")
  checklistSnapshot   Json         @map("checklist_snapshot")
  observacoesTecnicas String?      @map("observacoes_tecnicas") @db.Text

  ordemServico OrdemServico @relation(fields: [ordemServicoId], references: [id], onDelete: Cascade)
  equipamento  Equipamento  @relation(fields: [equipamentoId], references: [id])

  @@map("ordem_servico_itens")
}

// ─────────────────────────────────────────
// configuracao_empresa  (white-label / branding)
// ─────────────────────────────────────────
model ConfiguracaoEmpresa {
  id           String   @id @default(uuid()) @db.Uuid
  nomeEmpresa  String   @map("nome_empresa") @db.VarChar(255)
  nomeFantasia String?  @map("nome_fantasia") @db.VarChar(255)
  logoUrl      String?  @map("logo_url") @db.VarChar(512)
  corPrimaria  String?  @map("cor_primaria") @db.VarChar(7)
  cnpj         String?  @db.VarChar(18)
  telefone     String?  @db.VarChar(30)
  endereco     String?  @db.VarChar(255)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  // Google Calendar OAuth2
  googleConectado          Boolean   @default(false) @map("google_conectado")
  googleEmail              String?   @map("google_email") @db.VarChar(255)
  googleCalendarId         String?   @map("google_calendar_id") @db.VarChar(255)
  googleAccessToken        String?   @map("google_access_token") @db.Text
  googleRefreshToken       String?   @map("google_refresh_token") @db.Text
  googleTokenExpiry        DateTime? @map("google_token_expiry")

  @@map("configuracao_empresa")
}

// ─────────────────────────────────────────
// contratos
// ─────────────────────────────────────────
model Contrato {
  id             String    @id @default(uuid()) @db.Uuid
  clienteId      String    @map("cliente_id") @db.Uuid
  descricao      String    @db.VarChar(255)
  valorMensal    Decimal?  @map("valor_mensal") @db.Decimal(10, 2)
  vigenciaInicio DateTime  @map("vigencia_inicio")
  vigenciaFim    DateTime  @map("vigencia_fim")
  numOsIncluidas Int?      @map("num_os_incluidas")
  observacoes    String?   @db.Text
  ativo          Boolean   @default(true)
  criadoEm       DateTime  @default(now()) @map("criado_em")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  cliente Cliente @relation(fields: [clienteId], references: [id])

  @@index([clienteId, vigenciaFim])
  @@map("contratos")
}

// ─────────────────────────────────────────
// alerta_config  (configuração dos limiares)
// ─────────────────────────────────────────
model AlertaConfig {
  id                      String @id @default(uuid()) @db.Uuid
  osSemAtualizacaoDias    Int    @default(3)  @map("os_sem_atualizacao_dias")
  equipamentoCorretivasMes Int   @default(3)  @map("equipamento_corretivas_mes")
  contratoVencendoDias    Int    @default(30) @map("contrato_vencendo_dias")
  planoVencendoDias       Int    @default(30) @map("plano_vencendo_dias")

  @@map("alerta_config")
}

// ─────────────────────────────────────────
// alerta_ocorrencias
// ─────────────────────────────────────────
model AlertaOcorrencia {
  id           String           @id @default(uuid()) @db.Uuid
  tipo         AlertaTipo
  severidade   AlertaSeveridade
  titulo       String           @db.VarChar(255)
  descricao    String           @db.Text
  referenciaId String?          @map("referencia_id") @db.VarChar(255)
  resolvido    Boolean          @default(false)
  criadoEm    DateTime          @default(now()) @map("criado_em")
  resolvidoEm DateTime?         @map("resolvido_em")

  @@index([resolvido, criadoEm])
  @@map("alerta_ocorrencias")
}

model AuditoriaConflitoSincronizacao {
  id               String   @id @default(uuid()) @db.Uuid
  ordemServicoId   String   @map("ordem_servico_id") @db.Uuid
  payloadRejeitado Json     @map("payload_rejeitado")
  criadoEm        DateTime @default(now()) @map("criado_em")

  ordemServico OrdemServico @relation(fields: [ordemServicoId], references: [id])

  @@map("auditoria_conflitos_sincronizacao")
}
